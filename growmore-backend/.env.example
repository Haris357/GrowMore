# ─── Supabase (required) ───────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>

# ─── Firebase Admin — verifies client ID tokens (required) ─────────────────
FIREBASE_PROJECT_ID=<project-id>
FIREBASE_CLIENT_EMAIL=<service-account-email>
# Keep the quotes; newlines must be escaped as \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── AI (required for insights / news / commodity analysis) ────────────────
OPENAI_API_KEY=<your-openai-key>
OPENAI_MODEL=gpt-4.1-mini

# ─── Optional market-data keys ─────────────────────────────────────────────
COINGECKO_API_KEY=
NEWSAPI_KEY=
CRYPTOPANIC_API_KEY=

# ─── Data sources (defaults are fine) ──────────────────────────────────────
PSX_TERMINAL_BASE_URL=https://psxterminal.com
DPS_PSX_BASE_URL=https://dps.psx.com.pk

# ─── Application ───────────────────────────────────────────────────────────
APP_NAME=GrowMore
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ─── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTHENTICATED=120

# ─── Free-tier keep-alive (set automatically on Render) ────────────────────
# KEEP_ALIVE=1
